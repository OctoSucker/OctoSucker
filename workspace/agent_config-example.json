{
  "llm": {
    "baseURL": "",
    "apiKey": "",
    "model": "qwen3.5-plus"
  },
  "react": {
    "max_react_iterations": 20,
    "task_timeout_sec": 30,
    "max_tool_retries": 2,
    "tool_timeout_ms": 15000,
    "selector_semantic_candidate_limit": 24,
    "selector_embedding_cache_ttl_sec": 600,
    "workflow_binding_cache_path": "workspace/workflow_bindings.json",
    "memory_path": "workspace/memory",
    "embedding_model": "text-embedding-v3",
    "skill_workflows": [
      {
        "name": "research",
        "description": "发现信息、读取内容、整理结论",
        "steps": [
          { "name": "discover", "description": "发现候选信息源", "keywords": ["search", "find", "query", "web"], "tool": "search_web" },
          { "name": "read", "description": "读取和抽取信息", "keywords": ["read", "fetch", "open", "extract"] },
          { "name": "synthesize", "description": "输出总结结论", "keywords": ["summarize", "analyze", "report"] }
        ]
      }
    ]
  },
  "tool_providers": {
    "github.com/OctoSucker/tools-telegram": {
      "bot_token": "",
      "dm_policy": "pairing",
      "group_policy": "open",
      "require_mention": false,
      "allowed_user_ids": [2004898179],
      "max_message_store_size": 1000
    },
    "github.com/OctoSucker/tools-fs": {
      "workspace_dirs": [
        "workspace"
      ]
    },
    "github.com/OctoSucker/tools-web": {
      "fetch_max_chars": 50000
    },
    "github.com/OctoSucker/tools-mcp": {
      "servers": [
        { "id": "exa", "url": "https://mcp.exa.ai/mcp" },
        {
          "id": "context7",
          "url": "https://mcp.context7.com/mcp"
        }
      ]
    },
    "github.com/OctoSucker/tools-remember": {
      "storage_path": "workspace/remember.db",
      "max_content_size": 1048576
    },
    "github.com/OctoSucker/tools-cron": {
      "storage_path": "workspace/cron.db",
      "timezone": "Asia/Shanghai",
      "schedules": []
    },
    "github.com/OctoSucker/tools-exec": {
      "workspace_dirs": [
        "."
      ],
      "command_timeout_sec": 30,
      "command_blacklist": [
        "rm -rf /",
        "curl | bash",
        "wget -O- | bash",
        "curl | sh",
        "wget -O- | sh",
        "wget | bash",
        "wget | sh",
        "dd of=/dev/",
        "dd if=/dev/zero",
        "mkfs.",
        "chmod -R 777 /",
        "chown -R ",
        ":(){",
        "> /dev/sd",
        "> /dev/nvme",
        "shred /dev/"
      ],
      "sandbox_enabled": true,
      "sandbox_type": "docker",  
      "sandbox_cpu_sec": 60,
      "sandbox_memory_mb": 256,
      "sandbox_max_procs": 32,
      "sandbox_max_open_files": 64,
      "sandbox_network": "none",
      "docker_image": "alpine:latest",
      "docker_binary": "docker"
    }
  },
  "memory": {
    "memory_path": "workspace/memory",
    "embedding_model": "text-embedding-v3"
  }
}
